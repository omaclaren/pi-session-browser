{
  "name": "pi-session-browser",
  "version": "0.2.0",
  "description": "Local web UI for exploring, searching, and saving notes or bundles from pi sessions",
  "type": "module",
  "license": "MIT",
  "bin": {
    "pi-session-browser": "dist/cli.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omaclaren/pi-session-browser.git"
  },
  "keywords": [
    "pi",
    "pi-session",
    "session-browser",
    "search",
    "knowledge-management"
  ],
  "scripts": {
    "start": "tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
